# Server
PORT=3001
NODE_ENV=development

# LLM 对话模型配置
# 可选：openai / openai-compatible / other
# 以下非敏感字段可由管理后台修改，并原子回写到本地 .env。
LLM_PROVIDER=openai
LLM_API_BASE=
LLM_MODEL=gpt-4o-mini
# Secret: inject at runtime; the admin UI and SQLite never store this value.
LLM_API_KEY=

# Embedding 模型配置（独立于 LLM）
# 可选：openai / openai-compatible / other
# 管理后台只显示 API Key 是否已配置，不接收、显示或回写密钥内容。
EMBED_PROVIDER=openai
EMBED_API_BASE=
EMBED_MODEL=text-embedding-3-small
# Secret: inject at runtime; the admin UI and SQLite never store this value.
EMBED_API_KEY=

# Legacy fallback (如果未设置 LLM_API_KEY / OPENAI_MODEL / OPENAI_EMBED_MODEL，仍可用)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Authentication
JWT_SECRET=change-me-to-a-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Database
DB_PATH=./data/customer-service.db
DOCUMENT_UPLOAD_DIR=./data/uploads

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_CHAT=20
RATE_LIMIT_ADMIN=100
RATE_LIMIT_LOGIN=5

# Conversation lifecycle and bounded synchronous export
SESSION_INACTIVITY_MINUTES=30
CONVERSATION_EXPORT_MAX_MESSAGES=5000
