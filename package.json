{
  "name": "smart-customer-service",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered smart customer service system with admin panel",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc -p server/tsconfig.json && vite build",
    "start": "node dist/server/index.js",
    "db:init": "tsx server/db/index.ts",
    "db:seed": "tsx server/db/seed.ts",
    "test": "tsx server/tests/regression.test.ts && echo 'Test placeholder — run tsc checks' && tsc -p server/tsconfig.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.4.1",
    "openai": "^4.72.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tdesign-react": "^1.10.0",
    "tdesign-icons-react": "^0.3.4",
    "zustand": "^5.0.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.0",
    "papaparse": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^10.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/papaparse": "^5.3.15",
    "@types/multer": "^1.4.12",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0",
    "tailwindcss": "^3.4.15",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
